# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose: gemini | groq | ollama
LLM_PROVIDER=gemini

# Google Gemini (free tier: 1,500 req/day, no credit card needed)
# Get API key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Groq (free tier: ~14,400 req/day, no credit card needed)
# Get API key: https://console.groq.com
# GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama3-8b-8192

# Ollama (fully local, free — requires Ollama installed)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── Google Sheets (optional – task tracker) ───────────────────────────────────
# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=
